# 이 파일을 .env로 복사한 뒤 값을 채우세요. (.env는 git에 커밋되지 않음)

# Claude (일지 작성)
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-8

# Grok / xAI (시장·테크 분석, 라이브 검색)
XAI_API_KEY=xai-...
# GROK_MODEL=grok-4

# 워치리스트는 portfolio.md로 관리 (portfolio.example.md 참고)
# 투자 전제는 thesis.md로 관리 (thesis.example.md 참고)

# Notion (일지 발행 — integration을 만들어 대상 데이터베이스에 연결 필요)
NOTION_API_KEY=ntn_...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
