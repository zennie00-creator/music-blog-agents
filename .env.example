# 이 파일을 .env로 복사한 뒤 값을 채우세요. (.env는 git에 커밋되지 않음)

# Claude (일지 작성)
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-8

# Grok / xAI (시장·테크 분석, 라이브 검색)
XAI_API_KEY=xai-...
# GROK_MODEL=grok-4

# 워치리스트 (선택 — 미설정 시 기본 지수/반도체/빅테크 구성 사용)
# 형식: stooq심볼:표시이름 쉼표 구분. 예:
# WATCHLIST=^ndq:나스닥 100,^kospi:코스피,^sox:필라델피아 반도체,nvda.us:엔비디아,aapl.us:애플

# Notion (일지 발행 — integration을 만들어 대상 데이터베이스에 연결 필요)
NOTION_API_KEY=ntn_...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
